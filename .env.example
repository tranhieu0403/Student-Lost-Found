# Mẫu .env — copy file này thành .env và điền giá trị thật
# KHÔNG commit .env lên git

# --- Backend ---
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# --- Database (MySQL container) ---
# Chạy BE local + MySQL Docker: DB_HOST=localhost
# Chạy BE trong Docker: DB_HOST=db
DB_HOST=localhost
DB_PORT=3306
DB_NAME=lost_found_db
DB_USER=root
DB_PASSWORD=rootpassword123

# --- JWT ---
JWT_SECRET=dev_secret_minimum_32_characters_abc
JWT_EXPIRES_IN=7d

# --- Upload (Multer local) ---
UPLOAD_DIR=uploads

# --- Email (Mailtrap — đăng ký free tại mailtrap.io) ---
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@lostandfound.local

# --- Frontend (Vite) ---
VITE_API_URL=http://localhost:5000/api

# --- Compose port overrides (optional) ---
BE_PORT=5000
FE_PORT=80
